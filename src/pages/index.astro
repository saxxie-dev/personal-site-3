---
import SocialBar from "../components/SocialBar.astro";
import Layout from "../layouts/Layout.astro";
import VoronoiHero from "../components/VoronoiHero.astro";
---

<Layout title="saxxie.dev">
  <VoronoiHero />
  <div class="-mt-8 mb-16 px-4">
    <SocialBar />
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Blogposts Section -->
    <section>
      <h2 class="text-3xl font-extralight tracking-tight mb-8 border-b border-gray-200 dark:border-gray-800 pb-2">Words</h2>
      <div class="flex flex-col gap-6">
        <article class="group">
          <h3 class="text-xl font-medium mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
            <a href="/articles/monads-morally">Monads, Morally <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span></a>
          </h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            A curry-howard story exploring structural types and logic.
          </p>
        </article>
      </div>
    </section>

    <!-- Projects Section -->
    <section>
      <h2 class="text-3xl font-extralight tracking-tight mb-8 border-b border-gray-200 dark:border-gray-800 pb-2">Works</h2>
      <div class="flex flex-col gap-6">
        <article class="block bg-gray-50 dark:bg-gray-800/50 rounded-xl p-6 border border-gray-100 dark:border-gray-800 hover:border-emerald-500/30 transition-colors">
          <h3 class="text-xl font-medium mb-2">Space-Rep Learning App</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
            An intelligent flashcard scheduler built with Solid.js and Astro.
          </p>
          <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">
            <span>TypeScript</span> • <span>Solid</span>
          </div>
        </article>
      </div>
    </section>
  </div>
</Layout>
